# Foil Crafts — environment variables
# ───────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your Supabase project credentials.
# Get these from: Supabase Dashboard → Project Settings → API
# ───────────────────────────────────────────────────────────────────────────────

# Public — exposed to browser via Next.js (this is the ANON / RLS-protected key)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=ey-your-publishable-key-here

# Optional / server-only — full database access, NEVER expose to browser.
# Only needed if you add server actions that bypass RLS (e.g. admin batch tools).
# SUPABASE_SERVICE_ROLE_KEY=ey-your-service-role-key-here

# Production base URL — used in email redirect templates.
# Leave commented in dev; set in production env.
# NEXT_PUBLIC_SITE_URL=https://foilcrafts.com
